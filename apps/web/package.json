{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "generate:refractor-manifest": "node ./scripts/generate-refractor-manifest.mjs",
    "build": "bun run generate:refractor-manifest && vite build --outDir dist/client && vite build --ssr src/entry-server.tsx --outDir dist/server",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "test": "LUCENTDOCS_TEST_MODE=1 LUCENTDOCS_DATA_DIR=${LUCENTDOCS_TEST_DATA_DIR:-data-test} bun test src/",
    "test:e2e": "LUCENTDOCS_TEST_MODE=1 LUCENTDOCS_TEST_DATA_DIR=${LUCENTDOCS_TEST_DATA_DIR:-data-test} NODE_ENV=test PLAYWRIGHT_BROWSERS_PATH=${PLAYWRIGHT_BROWSERS_PATH:-$HOME/.cache/ms-playwright} playwright test"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@codemirror/lang-json": "^6.0.2",
    "@dnd-kit/core": "^6.3.1",
    "@floating-ui/dom": "^1.7.5",
    "@fontsource-variable/sora": "^5.2.8",
    "@fontsource-variable/source-serif-4": "^5.2.9",
    "@hookform/resolvers": "^5.2.2",
    "@lucentdocs/shared": "workspace:*",
    "@tailwindcss/vite": "^4.1.17",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-virtual": "^3.13.23",
    "@trpc/client": "^11.10.0",
    "@trpc/react-query": "^11.10.0",
    "@uiw/react-codemirror": "^4.25.4",
    "ai": "^6.0.97",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hast-util-to-html": "^9.0.5",
    "lucide-react": "^0.575.0",
    "markdown-it": "^14.1.1",
    "motion": "^12.40.0",
    "next-themes": "^0.4.6",
    "prosemirror-commands": "^1.7.1",
    "prosemirror-dropcursor": "^1.8.2",
    "prosemirror-gapcursor": "^1.4.0",
    "prosemirror-history": "^1.5.0",
    "prosemirror-inputrules": "^1.5.1",
    "prosemirror-keymap": "^1.2.3",
    "prosemirror-markdown": "^1.13.4",
    "prosemirror-model": "^1.25.4",
    "prosemirror-schema-list": "^1.5.1",
    "prosemirror-state": "^1.4.4",
    "prosemirror-view": "^1.41.6",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "^7.71.2",
    "react-resizable-panels": "^4.6.5",
    "react-router": "^7.13.0",
    "refractor": "^5.0.0",
    "shadcn": "^3.8.5",
    "sonner": "^2.0.7",
    "streamdown": "^1.0.0",
    "superjson": "^2.2.6",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.17",
    "tw-animate-css": "^1.4.0",
    "y-prosemirror": "^1.3.7",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.29",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/bun": "^1.3.9",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "vite": "^7.2.4"
  }
}
